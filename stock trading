import { useState, useEffect, useCallback, useRef } from "react";

// ─────────────────────────────────────────────
//  OOP CORE CLASSES
// ─────────────────────────────────────────────

class Stock {
  constructor(symbol, name, price, sector, volatility = 0.02) {
    this.symbol = symbol;
    this.name = name;
    this.price = price;
    this.openPrice = price;
    this.sector = sector;
    this.volatility = volatility;
    this.history = [{ time: Date.now(), price }];
    this.change = 0;
    this.changePct = 0;
    this.volume = Math.floor(Math.random() * 5000000) + 500000;
    this.marketCap = price * (Math.floor(Math.random() * 900) + 100) * 1000000;
    this.pe = +(Math.random() * 40 + 10).toFixed(1);
    this.week52High = price * (1 + Math.random() * 0.4);
    this.week52Low = price * (1 - Math.random() * 0.3);
  }

  tick() {
    const drift = (Math.random() - 0.495) * this.volatility;
    const newPrice = Math.max(0.01, this.price * (1 + drift));
    this.price = +newPrice.toFixed(2);
    this.change = +(this.price - this.openPrice).toFixed(2);
    this.changePct = +((this.change / this.openPrice) * 100).toFixed(2);
    this.volume += Math.floor(Math.random() * 10000);
    const now = Date.now();
    this.history.push({ time: now, price: this.price });
    if (this.history.length > 60) this.history.shift();
    return this;
  }

  getInfo() {
    return {
      symbol: this.symbol,
      name: this.name,
      price: this.price,
      change: this.change,
      changePct: this.changePct,
      sector: this.sector,
      volume: this.volume,
      marketCap: this.marketCap,
      pe: this.pe,
      week52High: +this.week52High.toFixed(2),
      week52Low: +this.week52Low.toFixed(2),
    };
  }
}

class Transaction {
  constructor(type, symbol, qty, price) {
    this.id = `txn-${Date.now()}-${Math.random().toString(36).slice(2, 6)}`;
    this.type = type; // 'BUY' | 'SELL'
    this.symbol = symbol;
    this.qty = qty;
    this.price = price;
    this.total = +(qty * price).toFixed(2);
    this.timestamp = Date.now();
  }
}

class Portfolio {
  constructor(userId, cash = 100000) {
    this.userId = userId;
    this.cash = cash;
    this.holdings = {}; // { symbol: { qty, avgCost } }
    this.transactions = [];
  }

  buy(symbol, qty, price) {
    const cost = qty * price;
    if (cost > this.cash) throw new Error("Insufficient funds");
    if (qty <= 0) throw new Error("Invalid quantity");
    this.cash = +(this.cash - cost).toFixed(2);
    if (!this.holdings[symbol]) this.holdings[symbol] = { qty: 0, avgCost: 0 };
    const h = this.holdings[symbol];
    const totalCost = h.qty * h.avgCost + cost;
    h.qty += qty;
    h.avgCost = +(totalCost / h.qty).toFixed(4);
    const txn = new Transaction("BUY", symbol, qty, price);
    this.transactions.unshift(txn);
    return txn;
  }

  sell(symbol, qty, price) {
    if (!this.holdings[symbol] || this.holdings[symbol].qty < qty)
      throw new Error("Not enough shares");
    if (qty <= 0) throw new Error("Invalid quantity");
    const h = this.holdings[symbol];
    h.qty -= qty;
    if (h.qty === 0) delete this.holdings[symbol];
    this.cash = +(this.cash + qty * price).toFixed(2);
    const txn = new Transaction("SELL", symbol, qty, price);
    this.transactions.unshift(txn);
    return txn;
  }

  getValue(stockMap) {
    let equity = 0;
    for (const [sym, h] of Object.entries(this.holdings)) {
      const s = stockMap[sym];
      if (s) equity += h.qty * s.price;
    }
    return +(this.cash + equity).toFixed(2);
  }

  getHoldingsPnL(stockMap) {
    return Object.entries(this.holdings).map(([sym, h]) => {
      const s = stockMap[sym];
      const currentPrice = s ? s.price : 0;
      const pnl = +((currentPrice - h.avgCost) * h.qty).toFixed(2);
      const pnlPct = +(((currentPrice - h.avgCost) / h.avgCost) * 100).toFixed(2);
      return { symbol: sym, qty: h.qty, avgCost: h.avgCost, currentPrice, pnl, pnlPct };
    });
  }

  serialize() {
    return JSON.stringify({ cash: this.cash, holdings: this.holdings, transactions: this.transactions.slice(0, 50) });
  }

  static deserialize(userId, data) {
    const p = new Portfolio(userId, 0);
    const parsed = JSON.parse(data);
    p.cash = parsed.cash;
    p.holdings = parsed.holdings;
    p.transactions = parsed.transactions || [];
    return p;
  }
}

class User {
  constructor(name, cash) {
    this.id = `user-${Date.now()}`;
    this.name = name;
    this.portfolio = new Portfolio(this.id, cash);
    this.netWorthHistory = [{ time: Date.now(), value: cash }];
  }

  recordNetWorth(stockMap) {
    const value = this.portfolio.getValue(stockMap);
    const now = Date.now();
    this.netWorthHistory.push({ time: now, value });
    if (this.netWorthHistory.length > 100) this.netWorthHistory.shift();
    return value;
  }
}


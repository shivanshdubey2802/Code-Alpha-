// ─────────────────────────────────────────────

const STORAGE_KEY = "trading_platform_v1";

export default function App() {
  const stockMapRef = useRef({});
  const [stocks, setStocks] = useState(() => {
    const map = {};
    INITIAL_STOCKS.forEach(s => { map[s.symbol] = s; });
    stockMapRef.current = map;
    return { ...map };
  });

  const userRef = useRef(null);
  const [user, setUser] = useState(null);
  const [setupDone, setSetupDone] = useState(false);
  const [userName, setUserName] = useState("Trader");

  const [tab, setTab] = useState("market");
  const [selectedStock, setSelectedStock] = useState(null);
  const [tradeStock, setTradeStock] = useState(null);
  const [tradeType, setTradeType] = useState("BUY");
  const [tradeQty, setTradeQty] = useState(1);
  const [tradeMsg, setTradeMsg] = useState(null);
  const [searchQuery, setSearchQuery] = useState("");
  const [sortBy, setSortBy] = useState("symbol");
  const [sortDir, setSortDir] = useState(1);

  // Init user from storage or fresh
  useEffect(() => {
    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved) {
        const data = JSON.parse(saved);
        const u = new User(data.name, 0);
        u.id = data.id;
        u.portfolio = Portfolio.deserialize(u.id, JSON.stringify(data.portfolio));
        u.netWorthHistory = data.netWorthHistory || [{ time: Date.now(), value: u.portfolio.cash }];
        userRef.current = u;
        setUser({ ...u, portfolio: { ...u.portfolio } });
        setSetupDone(true);
      }
    } catch {}
  }, []);

  const saveUser = useCallback((u) => {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify({
        id: u.id, name: u.name,
        portfolio: JSON.parse(u.portfolio.serialize()),
        netWorthHistory: u.netWorthHistory.slice(-100),
      }));
    } catch {}
  }, []);

  const handleSetup = () => {
    const u = new User(userName.trim() || "Trader", 100000);
    userRef.current = u;
    setUser({ ...u, portfolio: { ...u.portfolio } });
    saveUser(u);
    setSetupDone(true);
  };

  // Market tick every 1.5s
  useEffect(() => {
    const id = setInterval(() => {
      const map = stockMapRef.current;
      Object.values(map).forEach(s => s.tick());
      stockMapRef.current = { ...map };
      setStocks({ ...map });

      if (userRef.current) {
        userRef.current.recordNetWorth(stockMapRef.current);
        setUser(u => u ? { ...u, _t: Date.now() } : u);
      }
    }, 1500);
    return () => clearInterval(id);
  }, []);

  const syncUser = useCallback(() => {
    const u = userRef.current;
    if (!u) return;
    setUser({ name: u.name, id: u.id, portfolio: { ...u.portfolio, holdings: { ...u.portfolio.holdings }, transactions: [...u.portfolio.transactions] }, netWorthHistory: [...u.netWorthHistory] });
    saveUser(u);
  }, [saveUser]);

  const executeTrade = () => {
    const u = userRef.current;
    if (!u || !tradeStock) return;
    const stock = stockMapRef.current[tradeStock.symbol];
    const qty = parseInt(tradeQty);
    if (!qty || qty < 1) { setTradeMsg({ type: "error", text: "Enter a valid quantity." }); return; }
    try {
      if (tradeType === "BUY") u.portfolio.buy(stock.symbol, qty, stock.price);
      else u.portfolio.sell(stock.symbol, qty, stock.price);
      syncUser();
      setTradeMsg({ type: "success", text: `${tradeType} ${qty} × ${stock.symbol} @ ${fmt(stock.price)}` });
      setTimeout(() => setTradeMsg(null), 3000);
    } catch (e) {
      setTradeMsg({ type: "error", text: e.message });
    }
  };

  // ─── Views ───

  if (!setupDone) return (
    <div style={{ minHeight: "100vh", display: "flex", alignItems: "center", justifyContent: "center", background: "#0d1117", fontFamily: "'IBM Plex Mono', monospace" }}>
      <style>{`@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600&display=swap');`}</style>
      <div style={{ background: "#161b22", border: "1px solid #30363d", borderRadius: 12, padding: "40px 48px", maxWidth: 400, width: "100%", textAlign: "center" }}>
        <div style={{ fontSize: 36, marginBottom: 8 }}>📈</div>
        <h1 style={{ color: "#e6edf3", fontFamily: "'IBM Plex Mono'", fontSize: 22, marginBottom: 4 }}>TradeDesk</h1>
        <p style={{ color: "#8b949e", fontSize: 13, marginBottom: 28 }}>Simulated Stock Trading Platform</p>
        <input value={userName} onChange={e => setUserName(e.target.value)} onKeyDown={e => e.key === "Enter" && handleSetup()}
          placeholder="Your name" style={{ width: "100%", background: "#0d1117", border: "1px solid #30363d", borderRadius: 6, padding: "10px 14px", color: "#e6edf3", fontSize: 14, fontFamily: "'IBM Plex Mono'", marginBottom: 16, boxSizing: "border-box", outline: "none" }} />
        <button onClick={handleSetup} style={{ width: "100%", background: "#238636", border: "none", borderRadius: 6, padding: "11px 0", color: "#fff", fontSize: 14, fontFamily: "'IBM Plex Mono'", cursor: "pointer", fontWeight: 600 }}>
          Start with $100,000 →
        </button>
        <p style={{ color: "#484f58", fontSize: 11, marginTop: 16 }}>Virtual money only. No real trades.</p>
      </div>
    </div>
  );

  const totalValue = userRef.current ? userRef.current.portfolio.getValue(stockMapRef.current) : 0;
  const startValue = 100000;
  const totalPnL = +(totalValue - startValue).toFixed(2);
  const totalPnLPct = +((totalPnL / startValue) * 100).toFixed(2);
  const holdings = userRef.current ? userRef.current.portfolio.getHoldingsPnL(stockMapRef.current) : [];
  const transactions = user?.portfolio?.transactions || [];
  const netWorthHistory = userRef.current?.netWorthHistory || [];

  const stockList = Object.values(stocks);
  const filtered = stockList.filter(s =>
    s.symbol.includes(searchQuery.toUpperCase()) || s.name.toLowerCase().includes(searchQuery.toLowerCase())
  ).sort((a, b) => {
    const av = sortBy === "price" ? a.price : sortBy === "change" ? a.changePct : a.symbol;
    const bv = sortBy === "price" ? b.price : sortBy === "change" ? b.changePct : b.symbol;
    return (av < bv ? -1 : av > bv ? 1 : 0) * sortDir;
  });

  const detail = selectedStock ? stockMapRef.current[selectedStock] : null;

  // ─── STYLES ───
  const s = {
    app: { minHeight: "100vh", background: "#0d1117", fontFamily: "'IBM Plex Sans', sans-serif", color: "#e6edf3" },
    nav: { background: "#161b22", borderBottom: "1px solid #30363d", padding: "0 20px", display: "flex", alignItems: "center", gap: 0, height: 52 },
    logo: { color: "#58a6ff", fontFamily: "'IBM Plex Mono'", fontWeight: 600, fontSize: 16, marginRight: 32 },
    tab: (active) => ({ padding: "0 16px", height: "100%", display: "flex", alignItems: "center", fontSize: 13, fontWeight: 500, cursor: "pointer", color: active ? "#e6edf3" : "#8b949e", borderBottom: active ? "2px solid #58a6ff" : "2px solid transparent", background: "none", border: "none", borderBottom: active ? "2px solid #58a6ff" : "2px solid transparent", fontFamily: "'IBM Plex Sans'", gap: 6 }),
    main: { padding: "20px", maxWidth: 1100, margin: "0 auto" },
    card: { background: "#161b22", border: "1px solid #30363d", borderRadius: 10, padding: "16px 20px" },
    positive: { color: "#3fb950" },
    negative: { color: "#f85149" },
    neutral: { color: "#8b949e" },
    badge: (pos) => ({ display: "inline-block", padding: "2px 8px", borderRadius: 20, fontSize: 11, fontFamily: "'IBM Plex Mono'", background: pos ? "#1a3928" : "#3d1c1c", color: pos ? "#3fb950" : "#f85149", fontWeight: 600 }),
    th: { color: "#8b949e", fontSize: 11, fontFamily: "'IBM Plex Mono'", fontWeight: 500, padding: "8px 12px", textAlign: "left", borderBottom: "1px solid #21262d", cursor: "pointer", userSelect: "none" },
    td: { fontSize: 13, padding: "10px 12px", borderBottom: "1px solid #21262d" },
    btn: (variant) => ({ padding: "8px 20px", borderRadius: 6, fontSize: 13, fontWeight: 600, cursor: "pointer", fontFamily: "'IBM Plex Sans'", border: "none", background: variant === "buy" ? "#238636" : variant === "sell" ? "#b91c1c" : "#30363d", color: variant === "sell" ? "#fca5a5" : "#fff" }),
    input: { background: "#0d1117", border: "1px solid #30363d", borderRadius: 6, padding: "8px 12px", color: "#e6edf3", fontSize: 13, fontFamily: "'IBM Plex Mono'", outline: "none", width: 80 },
  };

  return (
    <div style={s.app}>
      <style>{`@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600&display=swap'); * { box-sizing: border-box; } ::-webkit-scrollbar { width: 4px; } ::-webkit-scrollbar-track { background: #0d1117; } ::-webkit-scrollbar-thumb { background: #30363d; border-radius: 2px; }`}</style>

      {/* NAV */}
      <nav style={s.nav}>
        <span style={s.logo}>📈 TradeDesk</span>
        {[["market", "Market"], ["portfolio", "Portfolio"], ["history", "History"]].map(([id, label]) => (
          <button key={id} style={s.tab(tab === id)} onClick={() => { setTab(id); setSelectedStock(null); }}>{label}</button>
        ))}
        <div style={{ flex: 1 }} />
        <div style={{ textAlign: "right" }}>
          <div style={{ fontSize: 12, color: "#8b949e" }}>{user?.name}</div>
          <div style={{ fontSize: 13, fontFamily: "'IBM Plex Mono'", color: totalPnL >= 0 ? "#3fb950" : "#f85149", fontWeight: 600 }}>{fmt(totalValue)}</div>
        </div>
      </nav>

      <div style={s.main}>

        {/* ── MARKET TAB ── */}
        {tab === "market" && !selectedStock && (
          <div>
            {/* Summary bar */}
            <div style={{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 12, marginBottom: 20 }}>
              {[
                { label: "Portfolio Value", val: fmt(totalValue), sub: null },
                { label: "Cash Available", val: fmt(userRef.current?.portfolio.cash || 0), sub: null },
                { label: "Total P&L", val: fmt(totalPnL), pos: totalPnL >= 0 },
                { label: "Return", val: `${totalPnLPct >= 0 ? "+" : ""}${totalPnLPct}%`, pos: totalPnLPct >= 0 },

                  </div>
                  <MiniChart data={detail.history} color={detail.changePct >= 0 ? "#3fb950" : "#f85149"} height={140} />
                  <div style={{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 12, marginTop: 16 }}>
                    {[["Market Cap", fmtM(detail.marketCap)], ["P/E Ratio", detail.pe], ["52W High", fmt(detail.week52High)], ["52W Low", fmt(detail.week52Low)]].map(([l, v]) => (
                      <div key={l} style={{ background: "#0d1117", borderRadius: 8, padding: "10px 12px" }}>
                        <div style={{ fontSize: 11, color: "#8b949e", marginBottom: 2 }}>{l}</div>
                        <div style={{ fontFamily: "'IBM Plex Mono'", fontSize: 14, fontWeight: 500 }}>{v}</div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>

              {/* Trade panel */}
              <div style={s.card}>
                <h3 style={{ margin: "0 0 16px", fontSize: 15, fontFamily: "'IBM Plex Mono'" }}>Trade {detail.symbol}</h3>
                <div style={{ display: "flex", gap: 8, marginBottom: 16 }}>
                  {["BUY", "SELL"].map(t => (
                    <button key={t} onClick={() => setTradeType(t)} style={{ flex: 1, padding: "9px 0", borderRadius: 6, border: "none", cursor: "pointer", fontWeight: 600, fontSize: 13, fontFamily: "'IBM Plex Mono'", background: tradeType === t ? (t === "BUY" ? "#238636" : "#b91c1c") : "#21262d", color: tradeType === t ? "#fff" : "#8b949e" }}>{t}</button>
                  ))}
                </div>
                <div style={{ marginBottom: 12 }}>
                  <div style={{ fontSize: 11, color: "#8b949e", marginBottom: 6 }}>QUANTITY</div>
                  <div style={{ display: "flex", gap: 8, alignItems: "center" }}>
                    <button onClick={() => setTradeQty(q => Math.max(1, q - 1))} style={{ ...s.btn("neutral"), padding: "6px 12px" }}>−</button>
                    <input type="number" min="1" value={tradeQty} onChange={e => setTradeQty(Math.max(1, parseInt(e.target.value) || 1))} style={{ ...s.input, width: 80, textAlign: "center" }} />
                    <button onClick={() => setTradeQty(q => q + 1)} style={{ ...s.btn("neutral"), padding: "6px 12px" }}>+</button>
                  </div>
                </div>
                <div style={{ background: "#0d1117", borderRadius: 8, padding: "12px", marginBottom: 16 }}>
                  {[["Price", fmt(detail.price)], ["Quantity", tradeQty], ["Estimated Total", fmt(detail.price * tradeQty)]].map(([l, v]) => (
                    <div key={l} style={{ display: "flex", justifyContent: "space-between", marginBottom: 6, fontSize: 13 }}>
                      <span style={{ color: "#8b949e" }}>{l}</span>
                      <span style={{ fontFamily: "'IBM Plex Mono'" }}>{v}</span>
                    </div>
                  ))}
                  <div style={{ borderTop: "1px solid #21262d", paddingTop: 6, display: "flex", justifyContent: "space-between", fontSize: 13 }}>
                    <span style={{ color: "#8b949e" }}>Cash available</span>
                    <span style={{ fontFamily: "'IBM Plex Mono'", color: "#3fb950" }}>{fmt(userRef.current?.portfolio.cash || 0)}</span>
                  </div>
                  {tradeType === "SELL" && userRef.current?.portfolio.holdings[detail.symbol] && (
                    <div style={{ display: "flex", justifyContent: "space-between", fontSize: 12, color: "#8b949e", marginTop: 4 }}>
                      <span>Shares owned</span>
                      <span style={{ fontFamily: "'IBM Plex Mono'" }}>{userRef.current.portfolio.holdings[detail.symbol].qty}</span>
                    </div>
                  )}
                </div>
                {tradeMsg && (
                  <div style={{ padding: "8px 12px", borderRadius: 6, marginBottom: 12, fontSize: 12, fontFamily: "'IBM Plex Mono'", background: tradeMsg.type === "success" ? "#1a3928" : "#3d1c1c", color: tradeMsg.type === "success" ? "#3fb950" : "#f85149", border: `1px solid ${tradeMsg.type === "success" ? "#2ea043" : "#f85149"}30` }}>{tradeMsg.text}</div>
                )}
                <button onClick={() => { setTradeStock(detail); executeTrade(); }} style={{ ...s.btn(tradeType.toLowerCase()), width: "100%", padding: "11px 0", fontSize: 14 }}>
                  {tradeType === "BUY" ? "Buy" : "Sell"} {tradeQty} Share{tradeQty > 1 ? "s" : ""}
                </button>
              </div>
            </div>
          </div>
        )}

        {/* ── PORTFOLIO TAB ── */}
        {tab === "portfolio" && (
          <div>
            <div style={{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 12, marginBottom: 20 }}>
              {[
                { label: "Total Value", val: fmt(totalValue) },
                { label: "Cash", val: fmt(userRef.current?.portfolio.cash || 0) },
                { label: "Equity", val: fmt(totalValue - (userRef.current?.portfolio.cash || 0)) },
                { label: "Total Return", val: `${totalPnLPct >= 0 ? "+" : ""}${totalPnLPct}%`, pos: totalPnLPct >= 0 },
              ].map((m, i) => (
                <div key={i} style={{ ...s.card, padding: "14px 16px" }}>
                  <div style={{ fontSize: 11, color: "#8b949e", marginBottom: 4, fontFamily: "'IBM Plex Mono'" }}>{m.label}</div>
                  <div style={{ fontSize: 20, fontWeight: 600, fontFamily: "'IBM Plex Mono'", color: m.pos === undefined ? "#e6edf3" : m.pos ? "#3fb950" : "#f85149" }}>{m.val}</div>
                </div>
              ))}
            </div>

            {/* Net worth chart */}
            <div style={{ ...s.card, marginBottom: 16 }}>
              <div style={{ fontSize: 12, color: "#8b949e", marginBottom: 12, fontFamily: "'IBM Plex Mono'" }}>NET WORTH OVER TIME</div>
              <MiniChart data={netWorthHistory} color={totalPnL >= 0 ? "#3fb950" : "#f85149"} height={100} />
            </div>

            {/* Holdings */}
            {holdings.length === 0 ? (
              <div style={{ ...s.card, textAlign: "center", padding: 40, color: "#484f58" }}>
                <div style={{ fontSize: 32, marginBottom: 8 }}>📭</div>
                <div>No holdings yet. Buy some stocks from the Market tab.</div>
              </div>
            ) : (
              <div style={s.card}>
                <div style={{ fontSize: 12, color: "#8b949e", marginBottom: 12, fontFamily: "'IBM Plex Mono'" }}>HOLDINGS</div>
                <table style={{ width: "100%", borderCollapse: "collapse" }}>
                  <thead>
                    <tr>
                      {["Symbol", "Shares", "Avg Cost", "Current Price", "Market Value", "P&L", "Return", ""].map(h => (
                        <th key={h} style={s.th}>{h}</th>
                      ))}
                    </tr>
                  </thead>
                  <tbody>
                    {holdings.map(h => {
                      const mv = +(h.qty * h.currentPrice).toFixed(2);
                      return (
                        <tr key={h.symbol} onMouseEnter={e => e.currentTarget.style.background = "#1c2128"} onMouseLeave={e => e.currentTarget.style.background = "transparent"}>
                          <td style={{ ...s.td, fontFamily: "'IBM Plex Mono'", color: "#58a6ff", fontWeight: 600, cursor: "pointer" }} onClick={() => { setTab("market"); setSelectedStock(h.symbol); }}>{h.symbol}</td>
                          <td style={{ ...s.td, fontFamily: "'IBM Plex Mono'" }}>{h.qty}</td>
                          <td style={{ ...s.td, fontFamily: "'IBM Plex Mono'", color: "#8b949e" }}>{fmt(h.avgCost)}</td>
                          <td style={{ ...s.td, fontFamily: "'IBM Plex Mono'" }}>{fmt(h.currentPrice)}</td>
                          <td style={{ ...s.td, fontFamily: "'IBM Plex Mono'" }}>{fmt(mv)}</td>
                          <td style={{ ...s.td, fontFamily: "'IBM Plex Mono'", color: h.pnl >= 0 ? "#3fb950" : "#f85149" }}>{h.pnl >= 0 ? "+" : ""}{fmt(h.pnl)}</td>
                          <td style={s.td}><span style={s.badge(h.pnlPct >= 0)}>{h.pnlPct >= 0 ? "+" : ""}{h.pnlPct}%</span></td>
                          <td style={s.td}>
                            <button style={s.btn("sell")} onClick={() => { setTab("market"); setSelectedStock(h.symbol); setTradeType("SELL"); }}>Sell</button>
                          </td>
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
              </div>
            )}
          </div>
        )}

        {/* ── HISTORY TAB ── */}
        {tab === "history" && (
          <div>
            <div style={{ ...s.card, marginBottom: 16 }}>
              <div style={{ fontSize: 12, color: "#8b949e", marginBottom: 12, fontFamily: "'IBM Plex Mono'" }}>TRANSACTION HISTORY ({transactions.length} trades)</div>
              {transactions.length === 0 ? (
                <div style={{ textAlign: "center", padding: "32px 0", color: "#484f58" }}>No transactions yet.</div>
              ) : (
                <table style={{ width: "100%", borderCollapse: "collapse" }}>
                  <thead>
                    <tr>
                      {["Type", "Symbol", "Shares", "Price", "Total", "Time"].map(h => (
                        <th key={h} style={s.th}>{h}</th>
                      ))}
                    </tr>
                  </thead>
                  <tbody>
                    {transactions.map(t => (
                      <tr key={t.id} onMouseEnter={e => e.currentTarget.style.background = "#1c2128"} onMouseLeave={e => e.currentTarget.style.background = "transparent"}>
                        <td style={s.td}><span style={{ ...s.badge(t.type === "BUY"), letterSpacing: 1 }}>{t.type}</span></td>
                        <td style={{ ...s.td, fontFamily: "'IBM Plex Mono'", color: "#58a6ff", fontWeight: 600 }}>{t.symbol}</td>
                        <td style={{ ...s.td, fontFamily: "'IBM Plex Mono'" }}>{t.qty}</td>
                        <td style={{ ...s.td, fontFamily: "'IBM Plex Mono'" }}>{fmt(t.price)}</td>
                        <td style={{ ...s.td, fontFamily: "'IBM Plex Mono'", fontWeight: 500 }}>{fmt(t.total)}</td>
                        <td style={{ ...s.td, fontSize: 12, color: "#8b949e" }}>{new Date(t.timestamp).toLocaleTimeString()}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              )}
            </div>

            {/* Stats */}
            {transactions.length > 0 && (() => {
              const buys = transactions.filter(t => t.type === "BUY");
              const sells = transactions.filter(t => t.type === "SELL");
              const totalBought = buys.reduce((a, t) => a + t.total, 0);
              const totalSold = sells.reduce((a, t) => a + t.total, 0);
              return (
                <div style={{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 12 }}>
                  {[["Total Trades", transactions.length], ["Buy Orders", buys.length], ["Sell Orders", sells.length], ["Volume Traded", fmt(totalBought + totalSold)]].map(([l, v]) => (
                    <div key={l} style={{ ...s.card, padding: "14px 16px" }}>
                      <div style={{ fontSize: 11, color: "#8b949e", marginBottom: 4, fontFamily: "'IBM Plex Mono'" }}>{l}</div>
                      <div style={{ fontSize: 18, fontWeight: 600, fontFamily: "'IBM Plex Mono'" }}>{v}</div>
                    </div>
                  ))}
                </div>
              );
            })()}
          </div>
        )}

        {/* Quick-trade modal (from market table Buy button) */}
        {tradeStock && tab === "market" && !selectedStock && (
          <div style={{ position: "fixed", inset: 0, background: "rgba(0,0,0,0.7)", display: "flex", alignItems: "center", justifyContent: "center", zIndex: 50 }}
            onClick={e => { if (e.target === e.currentTarget) { setTradeStock(null); setTradeMsg(null); } }}>
            <div style={{ background: "#161b22", border: "1px solid #30363d", borderRadius: 12, padding: "24px", width: 340 }}>
              <h3 style={{ margin: "0 0 16px", fontFamily: "'IBM Plex Mono'", color: "#58a6ff" }}>Quick Trade — {tradeStock.symbol}</h3>
              <div style={{ fontSize: 13, color: "#8b949e", marginBottom: 16 }}>Current Price: <strong style={{ color: "#e6edf3", fontFamily: "'IBM Plex Mono'" }}>{fmt(tradeStock.price)}</strong></div>
              <div style={{ display: "flex", gap: 8, marginBottom: 14 }}>
                {["BUY", "SELL"].map(t => (
                  <button key={t} onClick={() => setTradeType(t)} style={{ flex: 1, padding: "8px", borderRadius: 6, border: "none", cursor: "pointer", fontWeight: 600, fontSize: 13, background: tradeType === t ? (t === "BUY" ? "#238636" : "#b91c1c") : "#21262d", color: tradeType === t ? "#fff" : "#8b949e" }}>{t}</button>
                ))}
              </div>
              <div style={{ display: "flex", gap: 8, alignItems: "center", marginBottom: 16 }}>
                <button onClick={() => setTradeQty(q => Math.max(1, q - 1))} style={{ ...s.btn("neutral"), padding: "6px 12px" }}>−</button>
                <input type="number" min="1" value={tradeQty} onChange={e => setTradeQty(Math.max(1, parseInt(e.target.value) || 1))} style={{ ...s.input, flex: 1, textAlign: "center" }} />
                <button onClick={() => setTradeQty(q => q + 1)} style={{ ...s.btn("neutral"), padding: "6px 12px" }}>+</button>
              </div>
              <div style={{ background: "#0d1117", borderRadius: 8, padding: 12, marginBottom: 14, fontSize: 13, fontFamily: "'IBM Plex Mono'" }}>
                <div style={{ display: "flex", justifyContent: "space-between", color: "#8b949e" }}><span>Total</span><span style={{ color: "#e6edf3" }}>{fmt(tradeStock.price * tradeQty)}</span></div>
              </div>
              {tradeMsg && <div style={{ padding: "8px 12px", borderRadius: 6, marginBottom: 12, fontSize: 12, fontFamily: "'IBM Plex Mono'", background: tradeMsg.type === "success" ? "#1a3928" : "#3d1c1c", color: tradeMsg.type === "success" ? "#3fb950" : "#f85149" }}>{tradeMsg.text}</div>}
              <button onClick={executeTrade} style={{ ...s.btn(tradeType.toLowerCase()), width: "100%", padding: "11px 0" }}>
                Confirm {tradeType}
              </button>
            </div>
          </div>
        )}

      </div>
    </div>
  );
}

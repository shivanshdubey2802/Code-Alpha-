                      <h2 style={{ margin: 0, fontFamily: "'IBM Plex Mono'", color: "#58a6ff", fontSize: 24 }}>{detail.symbol}</h2>
                      <div style={{ color: "#8b949e", fontSize: 14 }}>{detail.name} · {detail.sector}</div>
